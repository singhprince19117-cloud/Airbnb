<style>
    @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600&family=Inter:wght@400;500;600&display=swap');

    .alert#flash-alert {
        font-family: 'Inter', sans-serif;
        border: 1px solid rgba(28, 43, 58, 0.16);
        border-radius: 0.9rem;
        padding: 1rem 1.4rem;
        box-shadow: none;
    }

    .alert#flash-alert h4 {
        font-family: 'Fraunces', serif;
        font-weight: 600;
        font-size: 1.05rem;
        margin: 0;
        color: #1c2b3a;
    }

    .alert-success#flash-alert {
        background: #eaf3ea;
        border-color: rgba(76, 139, 91, 0.3);
    }

    .alert-danger#flash-alert {
        background: #fbeae7;
        border-color: rgba(163, 64, 47, 0.25);
    }
</style>

<% if (success && success.length) { %>
    <div id="flash-alert" class="alert alert-success alert-dismissible fade show col-6 offset-3" role="alert">
        <h4 class="text-center">
            <%= success %>
        </h4>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    <script>
        setTimeout(() => {
            const alert = document.getElementById("flash-alert");
            if (alert) {
                const bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            }
        }, 10000);

    </script>
    <% } %>

        <% if (Delete && Delete.length) { %>
