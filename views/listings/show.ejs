<% layout("/layouts/boilerplate") %>

    <body>
        <style>
            @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@500&display=swap');

            :root {
                --ink: #1c2b3a;
                --ink-soft: #4b5a68;
                --line: rgba(28, 43, 58, 0.16);
                --gold: #b8863b;
                --gold-soft: #f3e6cd;
            }

            body {
                font-family: 'Inter', sans-serif;
                color: var(--ink);
            }

            h3 {
                font-family: 'Fraunces', serif;
                font-weight: 700;
                letter-spacing: -0.01em;
            }

            .show-card {
                border: none;
                padding: 0;
            }

            .show-image {
                height: 22rem;
                object-fit: cover;
                border-radius: 0.9rem;
            }

            .show-card>i {
                font-style: normal;
                font-size: 0.82rem;
                color: var(--ink-soft);
                margin-top: 0.75rem !important;
            }

            .card-body {
                padding: 1rem 0;
            }

            .card-body h5 {
                font-family: 'Fraunces', serif;
                font-weight: 600;
                font-size: 1.4rem;
                margin-bottom: 0.6rem;
            }

            .card-text {
                font-size: 0.92rem;
                color: var(--ink-soft);
                line-height: 1.7;
            }

            .card-text {
                font-family: 'IBM Plex Mono', monospace;
                font-size: 0.95rem;
                color: var(--ink);
            }

            .btns {
                display: flex;
                gap: 0.75rem;
                margin-left: 25%;
                margin-top: 1rem;
            }

            .btns .btn {
                border-radius: 999px;
                font-size: 0.85rem;
                font-weight: 500;
                padding: 0.5rem 1.3rem;
                border: none;
            }

            .btn.btn-warning {
                background: var(--gold-soft);
                color: #6b4d1c;
            }

            .btn.btn-warning:hover {
                background: var(--gold);
                color: #fff;
            }

            .btn.btn-dark {
                background: var(--ink);
            }

            .btn.btn-dark:hover {
                background: #0f1a24;
            }

            hr {
                border-color: var(--line);
                opacity: 1;
                margin: 2rem 0;
            }

            .starability-slot legend {
                font-family: 'Inter', sans-serif;
                font-weight: 600;
                font-size: 0.9rem;
                color: var(--ink-soft);
            }

            #comment.form-control {
                border: 1px solid var(--line);
                border-radius: 0.6rem;
                font-size: 0.95rem;
                box-shadow: none;
                transition: border-color 0.15s ease, box-shadow 0.15s ease;
            }

            #comment.form-control:focus {
                border-color: var(--gold);
                box-shadow: 0 0 0 3px var(--gold-soft);
            }

            label[for="comment"] h4 {
                font-family: 'Fraunces', serif;
                font-weight: 600;
                font-size: 1.1rem;
                margin-bottom: 0.5rem;
            }

            button.btn.btn-success {
                background: var(--ink);
                border: none;
                color: #fff;
                font-weight: 500;
                font-size: 0.9rem;
                padding: 0.65rem 1.6rem;
                border-radius: 999px;
                transition: background 0.15s ease;
            }

            button.btn.btn-success:hover {
                background: #0f1a24;
            }

            .review_card {
                border: 1px solid var(--line);
                border-radius: 0.9rem;
                padding: 1.1rem 1.3rem;
                margin-bottom: 1rem;
                background: #fff;
            }

            .review_card .card-title {
                font-family: 'Fraunces', serif;
                font-weight: 600;
                font-size: 1.05rem;
                color: var(--ink);
            }

            .review_card .card-text {
                font-family: 'Inter', sans-serif;
                color: var(--ink-soft);
                font-size: 0.9rem;
            }

            .review_card p.starability-result {
                margin-bottom: 0.75rem;
            }

            .review_card .btn.btn-danger {
                border-radius: 999px;
                font-size: 0.8rem;
                padding: 0.4rem 1.1rem;
                border: none;
            }

            #map {
                height: 20rem;
                border-radius: 0.9rem;
                border: 1px solid var(--line);
                margin-top: 1rem;
                margin-bottom: 2rem;
            }
        </style>

        <div class="row mt-3">
            <div class="col-8 offset-3">

                <h3 class="mt-2">Listing Details</h3>
            </div>
            <div class="card col-6 offset-3 show-card">
                <img src="<%=show_listing.image.url%>" class="card-img-top  show-image" alt="listing_image">
                <i class="mt-1">Owned by: <%=show_listing.owner.username %></i>
                <div class="card-body">
                    <p class="card-text">
                    <h5>
                        <%=show_listing.title%>
                    </h5><br>
                    <%= show_listing.description %> <br>
                        &#8377;<%= show_listing.price.toLocaleString("en-IN") %> <br>
                            <%= show_listing.location %> <br>
                                <%= show_listing.country %> <br>
                                    </p>
                </div>
            </div>
        </div>

        <div class="btns">
            <a href="/listings/<%=show_listing._id%>/edit" class="btn btn-warning offset-3 col-1">Edit</a>


            <form method="POST" action="/listings/<%=show_listing._id%>?_method=DELETE">
                <button class="btn btn-dark offset-3">Delete</button>
            </form>

        </div>


        <hr>
        <br>

        <div class="col-8 offset-3">
            <% if(currentUser){ %>
                <h3>Leave a review</h3>
                <br>
                <form action="/listings/<%= show_listing._id %>/reviews" method="POST" novalidate
                    class="needs-validation">
                    <div>
                        <fieldset class="starability-slot">
                            <legend>Rating:</legend>
                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0"
                                checked aria-label="No rating." />
                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                            <label for="first-rate1" title="Terrible">1 star</label>
                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                            <label for="first-rate2" title="Not good">2 stars</label>
                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                            <label for="first-rate3" title="Average">3 stars</label>
                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                            <label for="first-rate4" title="Very good">4 stars</label>
                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                            <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>
                    </div>
                    <br>
                    <div>
                        <label for="comment">
                            <h4>Comment:</h4>
                        </label>
                        <textarea class="form-control" name="review[comment]" id="comment" cols="30" rows="10"
                            required></textarea>

                        <div class="invalid-feedback">Please add some comments for review</div>

                    </div>
                    <br>
                    <button class="btn btn-success">Submit</button>

                    <br><br><br>
                </form>
                <% } %>


                    <hr>

                    <% if(show_listing.reviews.length> 0){ %>
                        <div>
                            <h3>All Reviews</h3>
                            <% for(review of show_listing.reviews){ %>
                                <div class="card review_card">
                                    <div class="card-body review_card"></div>
                                    <h4 class="card-title mb-3">
                                        <%=review.author.username%>
                                    </h4>
                                    <p class="card-text">Comment: <%=review.comment%>
                                    </p>
                                    <p>Rating:</p>
                                    <p class="starability-result card-text" data-rating="<%=review.rating%>">
                                        Rating
                                    </p>

                                    <form method="POST"
                                        action="/listings/<%=show_listing._id%>/reviews/<%=review._id%>?_method=DELETE">
                                        <button class="btn btn-danger">Delete</button>
                                    </form>
                                </div>
                                <% } %>
                        </div>
                        <% } %>

                            <hr>
        </div>

        <div class="col-8 offset-3">
            <h3>Where you'll be</h3>
            <div id="map"></div>
        </div>
    </body>