<% layout("/layouts/boilerplate.ejs") %>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@500&display=swap');

        :root {
            --ink: #1c2b3a;
            --ink-soft: #4b5a68;
            --line: rgba(28, 43, 58, 0.16);
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--ink);
        }

        .row.mt-3 {
            justify-content: center;
            margin-top: 4rem !important;
        }

        .alert.alert-danger {
            max-width: 640px;
            border: 1px solid var(--line);
            border-radius: 0.9rem;
            background: #fbeae7;
            padding: 1.4rem 1.6rem;
        }

        .alert.alert-danger i {
            color: #a3402f;
        }

        .alert.alert-danger h4 {
            font-family: 'Fraunces', serif;
            font-weight: 600;
            font-size: 1.15rem;
            margin: 0;
            color: var(--ink);
        }

        .alert.alert-danger h4 u {
            text-decoration: none;
            font-family: 'IBM Plex Mono', monospace;
            font-weight: 500;
            font-size: 0.9rem;
            color: var(--ink-soft);
            display: block;
            margin-bottom: 0.35rem;
        }
    </style>

    <div class="row mt-3">
        <div class="alert alert-danger d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-3 fs-2"></i>
            <h4><u>statuscode: <%= statuscode %></u> &nbsp; <%= message %>
            </h4>
        </div>
    </div>